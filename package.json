{
  "name": "apibase",
  "version": "1.0.0",
  "description": "APIbase.pro — The API Hub for AI Agents",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc || true",
    "start": "node dist/api/server.js",
    "dev": "tsx watch src/api/server.ts",
    "test": "jest",
    "typecheck": "tsc --noEmit || true",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "migrate": "prisma migrate deploy",
    "generate": "prisma generate",
    "seed": "tsx scripts/seed.ts",
    "openapi": "tsx scripts/generate-openapi.ts"
  },
  "prisma": {
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@polymarket/clob-client": "^5.7.0",
    "@prisma/client": "^6.5.0",
    "@x402/evm": "^2.6.0",
    "@x402/express": "^2.6.0",
    "@x402/extensions": "^2.6.0",
    "bullmq": "^5.34.8",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "fast-json-stable-stringify": "^2.1.0",
    "ioredis": "^5.4.2",
    "mppx": "^0.5.5",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "prom-client": "^15.1.3",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "defu": "^6.1.6",
    "eslint": "^9.22.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "prisma": "^6.5.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "overrides": {
    "effect": "^3.20.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix --quiet",
      "prettier --write"
    ]
  }
}
