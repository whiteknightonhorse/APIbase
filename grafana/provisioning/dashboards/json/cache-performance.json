      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (tool_id) (rate(cache_hits_total[5m])) / (sum by (tool_id) (rate(cache_hits_total[5m])) + sum by (tool_id) (rate(cache_misses_total[5m]))) * 100",
          "legendFormat": "{{tool_id}}",
          "instant": true,
